<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Vehicles</title>
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>
  <header>
    <h1>Used Car Dealership</h1>
    <nav>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/vehicles">Vehicles</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <section>
      <h2>Browse Vehicles</h2>

      <form method="get" action="/vehicles" style="margin-bottom:1rem;">
        <label for="category">Category</label>
        <select id="category" name="category">
          <option value="">All</option>
          <% if (categories && categories.length) { %>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.name %>" <%= (cat.name === (query && query.category)) ? 'selected' : '' %>><%= cat.name %></option>
            <% }) %>
          <% } %>
        </select>

        <label for="sort">Sort</label>
        <select id="sort" name="sort">
          <option value="">Default</option>
          <option value="price_asc" <%= (query && query.sort==='price_asc') ? 'selected' : '' %>>Price low→high</option>
          <option value="price_desc" <%= (query && query.sort==='price_desc') ? 'selected' : '' %>>Price high→low</option>
        </select>

        <button type="submit">Apply</button>
      </form>

      <% if (!vehicles || vehicles.length === 0) { %>
        <p>No vehicles found.</p>
      <% } else { %>
        <ul class="vehicle-list" style="list-style:none;padding:0;">
          <% vehicles.forEach(vehicle => { %>
            <li style="border:1px solid #ddd;padding:12px;margin-bottom:12px;">
              <a href="/vehicles/<%= vehicle.id %>" style="text-decoration:none;color:inherit;">
                <div style="display:flex;gap:12px;align-items:center;">
                  <div style="width:160px;height:100px;flex:0 0 160px;background:#f5f5f5;display:flex;align-items:center;justify-content:center;">
                    <% if (vehicle.image_url) { %>
                      <img src="<%= vehicle.image_url %>" alt="<%= vehicle.title %>" style="max-width:100%;max-height:100%;object-fit:cover;" />
                    <% } else { %>
                      <span style="color:#888;">No image</span>
                    <% } %>
                  </div>

                  <div>
                    <h3 style="margin:0 0 6px 0;"><%= vehicle.title %></h3>
                    <p style="margin:0 0 6px 0;"><strong>Price:</strong> $<%= vehicle.price %></p>
                    <p style="margin:0;color:#555;"><%= vehicle.make %> • <%= vehicle.model %> • <%= vehicle.year %> • <%= vehicle.miles %> miles</p>
                    <p style="margin-top:8px;color:#666;"><%= vehicle.description ? vehicle.description.substring(0,200) : '' %><%= vehicle.description && vehicle.description.length > 200 ? '…' : '' %></p>
                  </div>
                </div>
              </a>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  </main>
</body>
</html>
