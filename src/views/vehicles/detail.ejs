<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= vehicle.title %> - Vehicle Details</title>
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>
  <header>
    <h1><a href="/vehicles" style="text-decoration:none;color:inherit;">Vehicles</a></h1>
    <nav>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/vehicles">Vehicles</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <article>
      <h2><%= vehicle.title %></h2>
      <p><strong>Category:</strong> <%= vehicle.category || 'Uncategorized' %></p>
      <p><strong>Price:</strong> $<%= vehicle.price %></p>
      <p><strong>Make:</strong> <%= vehicle.make %> &nbsp; <strong>Model:</strong> <%= vehicle.model %> &nbsp; <strong>Year:</strong> <%= vehicle.year %></p>
      <p><strong>Miles:</strong> <%= vehicle.miles %></p>
      <p><strong>Availability:</strong> <%= vehicle.available ? 'Available' : 'Not available' %></p>

      <section style="margin-top:1rem;">
        <h3>Images</h3>
        <% if (images && images.length) { %>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <% images.forEach(img => { %>
              <div style="width:220px;height:140px;background:#f5f5f5;display:flex;align-items:center;justify-content:center;">
                <img src="<%= img.url %>" alt="<%= img.alt_text || vehicle.title %>" style="max-width:100%;max-height:100%;object-fit:cover;" />
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p>No images available.</p>
        <% } %>
      </section>

      <section style="margin-top:1rem;">
        <h3>Description</h3>
        <p><%= vehicle.description || 'No description provided.' %></p>
      </section>

      <section style="margin-top:1rem;">
        <h3>Reviews</h3>
        <% if (!reviews || reviews.length === 0) { %>
          <p>No reviews yet.</p>
        <% } else { %>
          <ul style="list-style:none;padding:0;">
            <% reviews.forEach(r => { %>
              <li style="border-top:1px solid #eee;padding:8px 0;">
                <p style="margin:0;"><strong><%= r.user_name || 'Anonymous' %></strong> — <%= r.rating %>/5</p>
                <p style="margin:4px 0 0 0;"><%= r.body %></p>
                <% if (user && user.id === r.user_id) { %>
                  <form method="post" action="/reviews/<%= r.id %>/delete" style="margin-top:6px;">
                    <button type="submit">Delete</button>
                    <a href="/reviews/<%= r.id %>/edit">Edit</a>
                  </form>
                <% } %>
              </li>
            <% }) %>
          </ul>
        <% } %>

        <% if (user) { %>
          <form method="post" action="/vehicles/<%= vehicle.id %>/reviews" style="margin-top:12px;">
            <h4>Leave a review</h4>
            <label for="rating">Rating</label>
            <select id="rating" name="rating" required>
              <option value="5">5</option>
              <option value="4">4</option>
              <option value="3">3</option>
              <option value="2">2</option>
              <option value="1">1</option>
            </select>
            <br />
            <label for="body">Review</label>
            <textarea id="body" name="body" rows="4" cols="50" required></textarea>
            <br />
            <button type="submit">Submit Review</button>
          </form>
        <% } else { %>
          <p><a href="/login">Log in</a> to leave a review or submit a service request.</p>
        <% } %>
      </section>

      <section style="margin-top:1rem;">
        <h3>Service Requests</h3>
        <% if (user) { %>
          <form method="post" action="/service-requests">
            <input type="hidden" name="vehicle_id" value="<%= vehicle.id %>" />
            <label for="description">Request description</label>
            <textarea id="description" name="description" rows="3" required></textarea>
            <br />
            <button type="submit">Submit Service Request</button>
          </form>

          <p style="margin-top:8px;"><a href="/my/service-requests">View your service request history</a></p>
        <% } else { %>
          <p><a href="/login">Log in</a> to submit a service request.</p>
        <% } %>
      </section>
    </article>
  </main>
</body>
</html>
