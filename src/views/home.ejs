<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Used Car Dealership - Home</title>
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>
  <%- include('partials/header', { user: user }) %>

  <main>
    <section>
      <h2>Featured Vehicles</h2>

      <% if (!featuredVehicles || featuredVehicles.length === 0) { %>
        <p>No featured vehicles at the moment. Check back soon.</p>
      <% } else { %>
        <div class="featured-grid" style="display:flex;gap:12px;flex-wrap:wrap;">
          <% featuredVehicles.forEach(v => { %>
            <article style="border:1px solid #ddd;padding:12px;width:320px;">
              <a href="/vehicles/<%= v.id %>" style="text-decoration:none;color:inherit;">
                <div style="height:180px;background:#f5f5f5;display:flex;align-items:center;justify-content:center;">
                  <% if (v.image_url) { %>
                    <img src="<%= v.image_url %>" alt="<%= v.title %>" style="max-width:100%;max-height:100%;object-fit:cover;" />
                  <% } else { %>
                    <span style="color:#888;">No image</span>
                  <% } %>
                </div>

                <h3 style="margin:8px 0 4px 0;"><%= v.title %></h3>
                <p style="margin:0 0 6px 0;color:#333;"><strong>Price:</strong> $<%= v.price %></p>
                <p style="margin:0;color:#666;"><%= v.make %> • <%= v.model %> • <%= v.year %></p>
              </a>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>

    <section style="margin-top:1.5rem;">
      <h2>Browse by Category</h2>
      <nav>
        <% if (categories && categories.length) { %>
          <% categories.forEach(cat => { %>
            <a href="/vehicles?category=<%= encodeURIComponent(cat.name) %>" style="margin-right:12px;"><%= cat.name %></a>
          <% }) %>
        <% } else { %>
          <p>No categories available.</p>
        <% } %>
      </nav>
    </section>

    <section style="margin-top:1.5rem;">
      <h2>Quick Links</h2>
      <ul>
        <li><a href="/vehicles">Browse all vehicles</a></li>
        <li><a href="/contact">Contact us</a></li>
        <li><a href="/login">Sign in</a> to leave reviews or submit service requests</li>
      </ul>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
